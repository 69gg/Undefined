{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "include": [
      "src/**/*.ts",
      "package.json",
      "tsconfig.json",
      "vite.config.ts",
      "src-tauri/tauri.conf.json",
      "src-tauri/capabilities/**/*.json"
    ]
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedVariables": "warn"
      }
    }
  }
}
