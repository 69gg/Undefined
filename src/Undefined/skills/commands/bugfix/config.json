{
  "name": "bugfix",
  "description": "分析聊天记录并生成 Bug 修复报告（仅管理员），目标用户支持 @ 提及",
  "usage": "/bugfix <QQ号|@用户1> [QQ号|@用户2] ... <开始时间> <结束时间>",
  "example": "/bugfix 123456 2024/12/01/09:00 now 或 /bugfix @某人 2024/12/01/09:00 now",
  "permission": "admin",
  "rate_limit": {
    "user": 10,
    "admin": 5,
    "superadmin": 0
  },
  "show_in_help": true,
  "order": 100,
  "allow_in_private": false,
  "aliases": []
}
