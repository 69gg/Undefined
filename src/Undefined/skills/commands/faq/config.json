{
    "name": "faq",
    "description": "FAQ 管理：列表/查看/搜索/删除（支持自动推断子命令）",
    "usage": "/faq(/f) [ls|view|search|del] [参数]",
    "example": "/faq 20241205-001",
    "permission": "public",
    "rate_limit": {
        "user": 10,
        "admin": 5,
        "superadmin": 0
    },
    "show_in_help": true,
    "order": 30,
    "allow_in_private": false,
    "aliases": ["f"],
    "subcommands": {
        "ls":    { "description": "列出所有FAQ" },
        "view":  { "description": "查看FAQ详情", "args": "<ID>" },
        "search":{ "description": "搜索FAQ", "args": "<关键词>" },
        "del":   { "description": "删除FAQ", "permission": "admin", "args": "<ID>" }
    },
    "inference": {
        "default": "ls",
        "rules": [
            { "pattern": "^\\d{8}-\\d{3}$", "subcommand": "view" }
        ],
        "fallback": "search"
    }
}
