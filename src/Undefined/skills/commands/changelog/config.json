{
  "name": "changelog",
  "description": "查看版本历史与单版本变更摘要",
  "usage": "/changelog [list [数量]|show <版本号>|latest|<版本号>|<数量>]",
  "example": "/changelog 3.2.6",
  "permission": "public",
  "rate_limit": {
    "user": 5,
    "admin": 0,
    "superadmin": 0
  },
  "show_in_help": true,
  "order": 15,
  "allow_in_private": true,
  "aliases": ["cl"],
  "subcommands": {
    "list": {
      "description": "按新到旧列出版本号与标题",
      "args": "[数量]"
    },
    "show": {
      "description": "展示指定版本的完整变更详情",
      "args": "<版本号>"
    },
    "latest": {
      "description": "展示最新版本的完整变更详情"
    }
  },
  "inference": {
    "default": "list",
    "rules": [
      { "pattern": "^\\d+$", "subcommand": "list" },
      { "pattern": "^[vV]?\\d+(?:\\.\\d+){1,3}(?:[-+][A-Za-z0-9._-]+)?$", "subcommand": "show" }
    ]
  }
}
